# =============================================================================
# Production (Coolify) — bu dəyərləri Coolify UI → Environment Variables bölməsinə
# əlavə edin. Lokal inkişaf üçün docker-compose.yml öz default-ları ilə işləyir.
# =============================================================================

# --- Məcburi (production) ---
POSTGRES_PASSWORD=change-me-strong-db-password
JWT_SECRET=change-me-at-least-32-random-characters-long
ADMIN_PASSWORD=change-me-strong-admin-password

# İctimai URL-lər (Coolify domain-ləri, https ilə)
# Admin panel domain-i — CORS və brauzer üçün
CORS_ORIGINS=https://admin.example.com
# API-nin ictimai URL-i (Swagger /health üçün; admin vasitəsilə də əlçatandır)
PUBLIC_URL=https://api.example.com

# --- İstəyə bağlı ---
POSTGRES_USER=diss
POSTGRES_DB=diss
ADMIN_USERNAME=admin

READ_STRATEGY=race
METRICS_BUFFER_SIZE=500
METRICS_USE_REDIS=true
METRICS_QUERY_FROM_REDIS=true
METRICS_REDIS_MAX_ENTRIES=5000
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800
ACCURACY_THRESHOLD=60
DECISION_DEFAULT_DB=postgres
DECISION_SAMPLE_SIZE=50
DECISION_MIN_SAMPLES=3

# --- Yalnız lokal docker-compose.yml (host portları) ---
# API_HOST_PORT=3001
# ADMIN_HOST_PORT=8080
# POSTGRES_HOST_PORT=5432
# MONGO_HOST_PORT=27017
# REDIS_HOST_PORT=6379
